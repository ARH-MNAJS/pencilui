{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "description": "pencilui documentation site",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-registry.mjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/copy-registry.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "clean": "rm -rf .next .turbo out public/r public/registry.json"
  },
  "dependencies": {
    "@pencilui/react": "workspace:*",
    "@pencilui/styles": "workspace:*",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^15.1.3",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@pencilui/eslint-config": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
